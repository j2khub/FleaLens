{
  "manifest_version": 3,
  "name": "플리렌즈 - 중고물품 시세 비교",
  "short_name": "플리렌즈",
  "version": "1.0.0",
  "description": "플리렌즈 - 당근마켓, 번개장터, 중고나라 시세를 한눈에 비교",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "sidePanel", "tabs", "scripting"],
  "host_permissions": [
    "https://www.daangn.com/*",
    "https://m.daangn.com/*",
    "https://www.bunjang.co.kr/*",
    "https://m.bunjang.co.kr/*",
    "https://api.bunjang.co.kr/*",
    "https://openapi.bunjang.co.kr/*",
    "https://web.joongna.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.daangn.com/*",
        "https://m.daangn.com/*",
        "https://www.bunjang.co.kr/*",
        "https://m.bunjang.co.kr/*",
        "https://web.joongna.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
